# Conexion a TimescaleDB/Postgres
POSTGRES_HOST=edge-timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=edge_data
POSTGRES_USER=change_me_db_user
POSTGRES_PASSWORD=change_me_db_password

# Seguridad del backend
APP_SECRET_KEY=change_me_super_secret_key
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=change_me_admin_password

# Esquema de eventos MQTT almacenados
TOPICS_TABLE=sensor_events
TOPICS_TIMESTAMP_COLUMN=recorded_at
TOPICS_NAME_COLUMN=topic
TOPICS_VALUE_COLUMN=value_double

# Configuracion de puertos y red
BACKEND_PORT=8000
FRONTEND_PORT=8080
EDGE_NETWORK=edge_net

