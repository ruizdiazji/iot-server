# Usuario y grupo del host para permisos de volumen
UID=1000
GID=1000

# Identidad del contenedor y red compartida
MOSQUITTO_CONTAINER_NAME=edge-mqtt
EDGE_NETWORK=edge_net

# Puertos expuestos
MQTT_PORT=1883
MQTT_WS_PORT=9001

# Recursos y zona horaria
MOSQUITTO_MEMORY_LIMIT=256m
MOSQUITTO_UID=1000
MOSQUITTO_GID=1000
TZ=UTC

# Credenciales MQTT
MOSQUITTO_USERNAME=change_me_mqtt_user
MOSQUITTO_PASSWORD=change_me_mqtt_password
