# Zona horaria del contenedor
TZ=UTC

# Red Docker externa compartida por todos los servicios
EDGE_NETWORK=edge_net

# Imagen y nombre del contenedor TimescaleDB/Postgres
TIMESCALEDB_IMAGE=timescale/timescaledb-ha:pg16
TIMESCALEDB_CONTAINER_NAME=edge-timescaledb

# Credenciales de la base
POSTGRES_USER=change_me_db_user
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=edge_data

# Puerto publicado en el host
POSTGRES_PORT=5432

# Telemetria de TimescaleDB
TIMESCALEDB_TELEMETRY=off

# Ingestor MQTT
MQTT_INGESTOR_CONTAINER_NAME=edge-mqtt-ingestor
MQTT_HOST=edge-mqtt
MQTT_PORT=1883
MQTT_USERNAME=change_me_mqtt_user
MQTT_PASSWORD=change_me_mqtt_password
MQTT_TOPIC=#

